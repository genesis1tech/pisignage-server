# piSignage Server — Environment Variables
# Copy to .env and fill in values before deploying

# Session secret (random string, used for cookie signing)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# MongoDB connection
# For local dev (no auth): mongodb://127.0.0.1:27017/pisignage-server-dev
# For Docker (no auth): mongodb://mongo:27017/pisignage-server-dev
# For Docker (with auth): mongodb://MONGO_USER:MONGO_PASS@mongo:27017/pisignage-server-dev?authSource=admin
# IMPORTANT: If you set MONGO_INITDB_ROOT_* below, you MUST also update this URI to include credentials
MONGOLAB_URI=mongodb://mongo:27017/pisignage-server-dev

# MongoDB root credentials (only used on first volume initialization — new deploys only)
# For existing deployments, create a user via mongosh first, then set these
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# Server port
PORT=3000
NODE_ENV=production

# HTTP Basic Auth override (overrides DB defaults if set)
# WARNING: Default credentials are pi:pi — change these immediately
AUTH_USER=
AUTH_PASSWORD=

# CORS allowed origins (comma-separated)
# Example: https://your-domain.com,http://localhost:3000
# If unset, only same-origin requests are allowed
CORS_ALLOWED_ORIGINS=

# Domain name (used for SSL/certbot)
DOMAIN=
